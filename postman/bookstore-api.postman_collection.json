{
  "info": {
    "_postman_id": "e56f3f6d-5a8e-4f95-af56-c485e995b3f2",
    "name": "Bookstore API Full Workflow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Bo test day du cho toan bo URL hien co: auth, users, categories, books, orders, rentals. Sap xep theo workflow thuc te."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "nonExistentId",
      "value": "999999"
    }
  ],
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.code).to.eql(1000);",
                  "pm.environment.set('adminToken', json.result.access_token);",
                  "pm.environment.set('accessToken', json.result.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.code).to.eql(1000);",
                  "pm.environment.set('userToken', json.result.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login sai mat khau - 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () { pm.response.to.have.status(401); });",
                  "pm.expect(pm.response.json().code).to.eql(9105);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Security Guard",
      "item": [
        {
          "name": "Public GET books khong token - 200",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/books?_page=0&_limit=5"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () { pm.response.to.have.status(200); });"] }
            }
          ]
        },
        {
          "name": "Protected GET orders khong token - 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', function () { pm.response.to.have.status(401); });", "pm.expect(pm.response.json().code).to.eql(9101);"] }
            }
          ]
        },
        {
          "name": "USER POST /categories - 403",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }]
            },
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Forbidden {{$timestamp}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Status 403', function () { pm.response.to.have.status(403); });", "pm.expect(pm.response.json().code).to.eql(9102);"] }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Categories Workflow (Admin)",
      "item": [
        {
          "name": "Create category",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Category {{$timestamp}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/categories"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('201', function(){pm.response.to.have.status(201);});", "pm.environment.set('categoryId', pm.response.json().result.id);"] } }]
        },
        {
          "name": "Get categories",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories?_page=0&_limit=10&_sort=categoryId&_order=asc&q=Category"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Get category by id",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Update category",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Category Updated {{$timestamp}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        }
      ]
    },
    {
      "name": "03 - Books Workflow",
      "item": [
        {
          "name": "Create book (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Book {{$timestamp}}\",\n  \"author_name\": \"Tac gia test\",\n  \"category_name\": \"Cong nghe\",\n  \"original_price\": 120000,\n  \"selling_price\": 100000,\n  \"total_stock\": 20,\n  \"status\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/books"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('201', function(){pm.response.to.have.status(201);});", "pm.environment.set('bookId', pm.response.json().result.id);"] } }]
        },
        {
          "name": "Get books public",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/books?_page=0&_limit=10&_sort=bookId&_order=asc&q=Book&category_name=Cong%20nghe"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Get book by id public",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/books/{{bookId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Update book (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"selling_price\": 99000,\n  \"total_stock\": 18\n}" },
            "url": "{{baseUrl}}/api/v1/books/{{bookId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        }
      ]
    },
    {
      "name": "04 - Users Workflow (Dang ky + Quan ly)",
      "description": "He thong hien tai khong co /auth/register public. Dang ky duoc thuc hien qua POST /api/v1/users boi ADMIN/STAFF.",
      "item": [
        {
          "name": "Dang ky user moi (Admin tao)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"workflow_user_{{$timestamp}}\",\n  \"password\": \"12345678\",\n  \"role_id\": {{createdUserRoleId}},\n  \"full_name\": \"Workflow User\",\n  \"email\": \"workflow_user_{{$timestamp}}@mail.com\",\n  \"status\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201', function(){pm.response.to.have.status(201);});",
                  "const json = pm.response.json();",
                  "pm.environment.set('managedUserId', json.result.id);",
                  "pm.environment.set('managedUsername', json.result.username);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get users",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users?_page=0&_limit=10&_sort=userId&_order=asc"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Get user by id",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/{{managedUserId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Update user",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Workflow User Updated\",\n  \"phone\": \"0912345678\"\n}" },
            "url": "{{baseUrl}}/api/v1/users/{{managedUserId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        }
      ]
    },
    {
      "name": "05 - Orders Workflow",
      "item": [
        {
          "name": "Create order (User role)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{managedUserId}},\n  \"shipping_address\": \"Ha Noi\",\n  \"payment_method\": \"COD\",\n  \"items\": [\n    {\n      \"book_id\": {{bookId}},\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/orders"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('201', function(){pm.response.to.have.status(201);});", "pm.environment.set('orderId', pm.response.json().result.id);"] } }]
        },
        {
          "name": "Get orders (User role)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders?_page=0&_limit=10&_sort=orderId&_order=desc&user_id={{managedUserId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Get order by id (User role)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Update order status (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"order_status\": \"Da xac nhan\",\n  \"payment_status\": \"Da thanh toan\"\n}" },
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "User PATCH order - 403",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"order_status\": \"Thu nghiem\"\n}" },
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('403', function(){pm.response.to.have.status(403);});", "pm.expect(pm.response.json().code).to.eql(9102);"] } }]
        }
      ]
    },
    {
      "name": "06 - Rentals Workflow",
      "description": "Create/Patch/Delete rental yeu cau ADMIN/STAFF theo SecurityConfig. Can bien bookItemId hop le trong environment.",
      "item": [
        {
          "name": "Get rentals (User role)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/rentals?_page=1&_limit=10&_sort=rentalId&_order=desc"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Create rental (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{managedUserId}},\n  \"book_item_id\": {{bookItemId}},\n  \"payment_method\": \"Tien mat\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/rentals"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200', function(){pm.response.to.have.status(200);});",
                  "const json = pm.response.json();",
                  "if (json.result && json.result.id) { pm.environment.set('rentalId', json.result.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get rental by id",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/rentals/{{rentalId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        },
        {
          "name": "Update rental status (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Da tra\",\n  \"payment_status\": \"Hoan tat\"\n}" },
            "url": "{{baseUrl}}/api/v1/rentals/{{rentalId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('200', function(){pm.response.to.have.status(200);});"] } }]
        }
      ]
    },
    {
      "name": "99 - Cleanup Workflow",
      "item": [
        {
          "name": "Delete rental",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/rentals/{{rentalId}}"
          }
        },
        {
          "name": "Delete order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          }
        },
        {
          "name": "Delete book",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/books/{{bookId}}"
          }
        },
        {
          "name": "Delete category",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete user",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/users/{{managedUserId}}"
          }
        }
      ]
    }
  ]
}
