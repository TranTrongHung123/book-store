  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Login admin - 200",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.code).to.eql(1000);",
                  "pm.expect(json.result.access_token).to.be.a('string').and.not.empty;",
                  "pm.environment.set('adminToken', json.result.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register managed user - 201",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"pm_user_{{$timestamp}}\",\n  \"password\": \"{{managedUserPassword}}\",\n  \"full_name\": \"Postman User {{$timestamp}}\",\n  \"email\": \"pm_user_{{$timestamp}}@mail.test\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.expect(json.code).to.eql(1000);",
                  "pm.expect(json.result.id).to.be.a('number');",
                  "pm.environment.set('managedUserId', String(json.result.id));",
                  "pm.environment.set('managedUsername', json.result.username);",
                  "pm.environment.set('managedUserEmail', json.result.email || '');"
                ]
              }
            }
          ]
        },
        {
